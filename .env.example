# TG Video Search Bot - 环境变量配置示例
# 复制为 .env 并填写实际值

# Telegram Bot Token（必填）
BOT_TOKEN=your_bot_token_here

# 管理员Telegram ID（必填，多个用逗号分隔）
ADMIN_IDS=your_admin_id_here

# 代理设置（true/false）
PROXY_ENABLED=false

# 搜索设置
MAX_SEARCH_RESULTS=30
MAX_RESULTS_PER_SOURCE=15

# 搜索超时（秒）
SEARCH_TIMEOUT_GUOCHAN=10.0
SEARCH_TIMEOUT_HANIME=12.0
SEARCH_TIMEOUT_JAV=10.0
SEARCH_TIMEOUT_OUMEI=10.0

# 缓存设置
CACHE_TTL=300
CACHE_MAX_ENTRIES=500

# 频率限制（每分钟最大搜索次数）
MAX_SEARCHES_PER_MINUTE=10

# Webhook模式（留空则使用Polling模式）
WEBHOOK_URL=
PORT=8000

# 数据库路径
DB_PATH=data/bot.db
