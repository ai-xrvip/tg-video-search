import os
from dotenv import load_dotenv

load_dotenv()

# Bot Token (REQUIRED)
BOT_TOKEN = os.getenv("BOT_TOKEN", "")

# Admin IDs (REQUIRED, comma-separated)
ADMIN_IDS = os.getenv("ADMIN_IDS", "")

# Webhook URL (leave empty for polling mode / local dev)
WEBHOOK_URL = os.getenv("WEBHOOK_URL", "")

# Port (for Railway / webhook)
PORT = os.getenv("PORT", "8000")

# Database path
DB_PATH = os.getenv("DB_PATH", "data/bot.db")

# Proxy
PROXY_ENABLED = os.getenv("PROXY_ENABLED", "false")

# Search settings
MAX_SEARCH_RESULTS = os.getenv("MAX_SEARCH_RESULTS", "30")
MAX_RESULTS_PER_SOURCE = os.getenv("MAX_RESULTS_PER_SOURCE", "15")

# Search timeouts (seconds)
SEARCH_TIMEOUT_GUOCHAN = os.getenv("SEARCH_TIMEOUT_GUOCHAN", "10.0")
SEARCH_TIMEOUT_HANIME = os.getenv("SEARCH_TIMEOUT_HANIME", "12.0")
SEARCH_TIMEOUT_JAV = os.getenv("SEARCH_TIMEOUT_JAV", "10.0")
SEARCH_TIMEOUT_OUMEI = os.getenv("SEARCH_TIMEOUT_OUMEI", "10.0")
